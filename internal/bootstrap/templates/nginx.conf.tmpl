user {{ .NginxUser }}  nobody;
worker_processes auto;
worker_rlimit_nofile 65535;

thread_pool default_pool threads=32 max_queue=65536;

events {
    worker_connections 4096;
    multi_accept on;
    use epoll;
}

http {
    include mime.types;
    default_type application/octet-stream;

    sendfile on;
    keepalive_timeout 65;

    http3 on;
    quic_gso on;
    quic_retry on;

    gzip_vary on;
    gzip on;
    gzip_static on;

    # Global cache zones used by generated site configs.
    # Cache root: {{ .CacheRoot }}
    fastcgi_cache_path {{ .PHPFastCGICachePath }} levels=1:2 keys_zone=php_cache:64m inactive=30m max_size=1g use_temp_path=off;
    proxy_cache_path   {{ .ProxyMicroCachePath }} levels=1:2 keys_zone=proxy_micro:32m inactive=30m max_size=512m use_temp_path=off;
    proxy_cache_path   {{ .ProxyStaticCachePath }} levels=1:2 keys_zone=proxy_static:128m inactive=30d max_size=2g use_temp_path=off;

    server {
        listen 80 default_server;
        listen [::]:80 default_server;
        server_name _;

        root /var/www/html;

        location ^~ /.well-known/acme-challenge/ {
            default_type text/plain;
            try_files $uri =404;
        }

        location / {
            return 444;
        }
    }

    server {
        listen 443 ssl default_server;
        listen [::]:443 ssl default_server;
        listen 443 quic reuseport;
        server_name _;

        ssl_certificate     {{ .TLSCert }};
        ssl_certificate_key {{ .TLSKey }};

        ssl_protocols TLSv1.3;
        http3 on;

        return 444;
    }

    include {{ .SitesIncludeGlob }};
}
